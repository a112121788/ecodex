<Window x:Class="ECode.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ECode.ViewModels"
        xmlns:views="clr-namespace:ECode.Views"
        xmlns:controls="clr-namespace:ECode.Controls"
        Title="ECode" Height="800" Width="1200"
        MinHeight="400" MinWidth="600"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="CanResize"
        Background="Transparent"
        Loaded="OnLoaded" Closing="OnClosing"
        KeyDown="OnKeyDown">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="38" CornerRadius="0" GlassFrameThickness="0"
                      ResizeBorderThickness="6" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#FF11130F" />
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#FFE7E4D6" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF27301F" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFE7E4D6" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FF11130F" />
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FF11130F" />

        <SolidColorBrush x:Key="{x:Static SystemColors.MenuBarBrushKey}" Color="#FF11130F" />
        <SolidColorBrush x:Key="{x:Static SystemColors.MenuHighlightBrushKey}" Color="#FF27301F" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="#FF34372F" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightLightBrushKey}" Color="#FF34372F" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkBrushKey}" Color="#FF34372F" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkDarkBrushKey}" Color="#FF34372F" />

        <Style x:Key="AppMenuStyle" TargetType="Menu">
            <Setter Property="Background" Value="{StaticResource SidebarBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
            <Setter Property="Padding" Value="4,2" />
        </Style>

        <Style x:Key="AppMenuTopItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Margin" Value="0,0,2,0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Grid>
                            <Border x:Name="TopItemBg" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter ContentSource="Header" RecognizesAccessKey="True" />
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="None"
                                   IsOpen="{TemplateBinding IsSubmenuOpen}">
                                <Border Background="#FF11130F" BorderBrush="#FF34372F" BorderThickness="1" Padding="4" SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle" />
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="TopItemBg" Property="Background" Value="#FF1C2118" />
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="TopItemBg" Property="Background" Value="#FF1C2118" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AppMenuSubItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="SubItemBg" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0" ContentSource="Header" RecognizesAccessKey="True" />
                                <TextBlock Grid.Column="1" Text="{TemplateBinding InputGestureText}" Margin="14,0,0,0"
                                           Foreground="{StaticResource ForegroundDimBrush}" FontSize="11" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="SubItemBg" Property="Background" Value="#FF27301F" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource ForegroundDimBrush}" />
                                <Setter TargetName="SubItemBg" Property="Opacity" Value="0.75" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AppMenuSeparatorStyle" TargetType="Separator">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1" Margin="6,4" Background="#FF34372F" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Border x:Name="WindowBorder" Background="{StaticResource AppWindowBackgroundBrush}"
            CornerRadius="{StaticResource WindowCornerRadius}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Border.Clip>
            <RectangleGeometry x:Name="WindowClipGeometry" RadiusX="10" RadiusY="10" />
        </Border.Clip>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Custom title bar -->
            <Border Grid.Row="0" Background="{StaticResource SurfaceTabBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid Height="38">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" /> <!-- Menu items -->
                        <ColumnDefinition Width="*" />    <!-- Drag area -->
                        <ColumnDefinition Width="Auto" /> <!-- Window buttons -->
                    </Grid.ColumnDefinitions>

                    <!-- Menu items (left side) -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock Text="ECode" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}"
                                   VerticalAlignment="Center" Margin="14,0,12,0" />
                        <Menu Style="{StaticResource AppMenuStyle}" VerticalAlignment="Center">
                            <Menu.Resources>
                                <Style TargetType="Separator" BasedOn="{StaticResource AppMenuSeparatorStyle}" />
                            </Menu.Resources>
                            <MenuItem Header="文件(_F)" Style="{StaticResource AppMenuTopItemStyle}" ItemContainerStyle="{StaticResource AppMenuSubItemStyle}">
                                <MenuItem Header="新建项目(_N)" Command="{Binding CreateNewWorkspaceCommand}" InputGestureText="Ctrl+N" />
                                <MenuItem Header="新建标签页(_S)" Command="{Binding SelectedWorkspace.CreateNewSurfaceCommand}" InputGestureText="Ctrl+T" />
                                <MenuItem Header="命令日志(_L)" Click="MenuOpenLogs_Click" InputGestureText="Ctrl+Shift+L" />
                                <MenuItem Header="会话存档(_V)" Click="MenuOpenSessionVault_Click" InputGestureText="Ctrl+Shift+V" />
                                <MenuItem Header="恢复会话(_O)" Click="MenuRestoreSession_Click" InputGestureText="Ctrl+Shift+O" />
                                <MenuItem Header="重载 ecode.json(_R)" Click="MenuReloadConfig_Click" InputGestureText="Ctrl+Shift+," />
                                <MenuItem Header="设置(_S)" Click="MenuOpenSettings_Click" InputGestureText="Ctrl+," />
                                <MenuItem Header="退出(_X)" Click="CloseButton_Click" />
                            </MenuItem>
                            <MenuItem Header="窗口(_W)" Style="{StaticResource AppMenuTopItemStyle}" ItemContainerStyle="{StaticResource AppMenuSubItemStyle}">
                                <MenuItem Header="向右分屏(_R)" Click="ToolbarSplitRight_Click" InputGestureText="Ctrl+D" />
                                <MenuItem Header="向下分屏(_D)" Click="ToolbarSplitDown_Click" InputGestureText="Ctrl+Shift+D" />
                                <MenuItem Header="缩放面板(_Z)" Click="ToolbarZoom_Click" InputGestureText="Ctrl+Shift+Z" />
                                <MenuItem Header="等宽面板(_E)" Click="ToolbarEqualize_Click" />
                                <MenuItem Header="搜索(_S)" Click="Search_Click" InputGestureText="Ctrl+Shift+F" />
                                <MenuItem Header="命令面板(_P)" Click="CommandPalette_Click" InputGestureText="Ctrl+Shift+P" />
                                <MenuItem Header="片段(_S)" Click="Snippets_Click" />
                                <MenuItem Header="切换侧边栏(_B)" Command="{Binding ToggleSidebarCommand}" InputGestureText="Ctrl+B" />
                            </MenuItem>
                            <MenuItem Header="帮助(_H)" Style="{StaticResource AppMenuTopItemStyle}" ItemContainerStyle="{StaticResource AppMenuSubItemStyle}">
                                <MenuItem Header="键盘快捷键" Click="MenuOpenKeyboardShortcuts_Click" />
                                <MenuItem Header="关于" Click="MenuAbout_Click" />
                            </MenuItem>
                        </Menu>
                    </StackPanel>

                    <!-- Drag area (center) -->
                    <Border Grid.Column="1" Background="Transparent"
                            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" />

                    <!-- Window control buttons (right side) -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Style="{StaticResource WindowChromeButton}" Click="MinimizeButton_Click"
                                ToolTip="最小化">
                            <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                        </Button>
                        <Button x:Name="MaxRestoreButton" Style="{StaticResource WindowChromeButton}"
                                Click="MaximizeButton_Click" ToolTip="最大化">
                            <TextBlock x:Name="MaxRestoreIcon" Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                        </Button>
                        <Button Style="{StaticResource WindowCloseButton}" Click="CloseButton_Click"
                                ToolTip="关闭">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SidebarColumn" Width="280" />
                    <ColumnDefinition Width="1" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border x:Name="SidebarBorder" Grid.Column="0" Background="{StaticResource SidebarGradientBrush}">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Sidebar top actions -->
                        <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,0,0,1" Padding="8,8,8,6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Vertical">
                                    <TextBlock Text="项目" Foreground="{StaticResource ForegroundBrush}" FontSize="12" FontWeight="SemiBold" />
                                    <TextBlock Text="管理会话与环境" Foreground="{StaticResource ForegroundDimBrush}" FontSize="10" />
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Style="{StaticResource IconButton}" ToolTip="新建项目 (Ctrl+N)"
                                            Width="24" Height="24" Command="{Binding CreateNewWorkspaceCommand}">
                                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                                    </Button>
                                    <Button Style="{StaticResource IconButton}" ToolTip="会话存档 (Ctrl+Shift+V)"
                                            Width="24" Height="24" Click="MenuOpenSessionVault_Click">
                                        <TextBlock Text="&#xE8D1;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                                    </Button>
                                    <Button Style="{StaticResource IconButton}" ToolTip="命令日志 (Ctrl+Shift+L)"
                                            Width="24" Height="24" Click="MenuOpenLogs_Click">
                                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                                    </Button>
                                </StackPanel>

                                <TextBox x:Name="WorkspaceFilterBox"
                                         Grid.Row="1" Grid.ColumnSpan="2"
                                         Margin="0,8,0,0" Padding="8,5"
                                         Background="#FF11130F" Foreground="{StaticResource ForegroundBrush}"
                                         BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                         CaretBrush="{StaticResource ForegroundBrush}" SelectionBrush="{StaticResource AccentBrush}"
                                         ToolTip="按名称、分支或目录过滤项目"
                                         TextChanged="WorkspaceFilterBox_TextChanged" />
                            </Grid>
                        </Border>

                        <!-- Workspace list -->
                        <ListBox Grid.Row="1" ItemsSource="{Binding Workspaces}"
                                 SelectedItem="{Binding SelectedWorkspace}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 AllowDrop="True" Padding="4,4,4,0"
                                 x:Name="WorkspaceList">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:WorkspaceViewModel}">
                                    <controls:WorkspaceSidebarItem />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,1" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Grid>
                                                    <!-- Active indicator bar (left edge) -->
                                                    <Rectangle x:Name="activeBar" Width="3" HorizontalAlignment="Left"
                                                               RadiusX="1.5" RadiusY="1.5" Opacity="0"
                                                               Margin="0,4">
                                                        <Rectangle.Fill>
                                                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                                <GradientStop Color="#FF1FA0FF" Offset="0" />
                                                                <GradientStop Color="#FFE6C56E" Offset="1" />
                                                            </LinearGradientBrush>
                                                        </Rectangle.Fill>
                                                    </Rectangle>
                                                    <Border x:Name="border" Background="{TemplateBinding Background}"
                                                            CornerRadius="8" Padding="10,8" Margin="6,0,2,0">
                                                        <ContentPresenter />
                                                    </Border>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background"
                                                                Value="{StaticResource SidebarItemHoverBrush}" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="border" Property="Background"
                                                                Value="{StaticResource SidebarItemSelectedBrush}" />
                                                        <Setter TargetName="activeBar" Property="Opacity" Value="1" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <EventSetter Event="PreviewMouseLeftButtonDown" Handler="WorkspaceItem_PreviewMouseDown" />
                                    <EventSetter Event="PreviewMouseMove" Handler="WorkspaceItem_PreviewMouseMove" />
                                    <EventSetter Event="DragOver" Handler="WorkspaceItem_DragOver" />
                                    <EventSetter Event="Drop" Handler="WorkspaceItem_Drop" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>

                        <!-- Sidebar footer -->
                        <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,1,0,0" Padding="6,6">
                            <StackPanel>
                                <Button Command="{Binding CreateNewWorkspaceCommand}"
                                        Style="{StaticResource ECodeButton}"
                                        HorizontalAlignment="Stretch" Margin="0,1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                   Margin="0,0,8,0" Opacity="0.6" />
                                        <TextBlock Text="新建项目" FontSize="12" />
                                    </StackPanel>
                                </Button>

                                <Button Command="{Binding ToggleNotificationPanelCommand}"
                                        Style="{StaticResource ECodeButton}"
                                        HorizontalAlignment="Stretch" Margin="0,1">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xEA8F;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                       Margin="0,0,8,0" Opacity="0.6" />
                                            <TextBlock Text="通知" FontSize="12" />
                                        </StackPanel>
                                        <Border CornerRadius="10"
                                                Padding="6,2" HorizontalAlignment="Right"
                                                Visibility="{Binding TotalUnreadCount, Converter={StaticResource IntToVisibility}}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#FF1FA0FF" Offset="0" />
                                                    <GradientStop Color="#FFE6C56E" Offset="1" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock Text="{Binding TotalUnreadCount}" FontSize="10"
                                                       Foreground="White" FontWeight="SemiBold" />
                                        </Border>
                                    </Grid>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Vertical divider -->
                <GridSplitter x:Name="SidebarSplitter" Grid.Column="1" Width="1" Background="{StaticResource BorderBrush}"
                              HorizontalAlignment="Stretch" />

                <!-- Content area -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /> <!-- Surface tabs -->
                        <RowDefinition Height="Auto" /> <!-- Toolbar -->
                        <RowDefinition Height="*" />    <!-- Terminal content -->
                        <RowDefinition Height="Auto" /> <!-- Status bar -->
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Surface tabs -->
                    <controls:SurfaceTabBar x:Name="SurfaceTabBarControl" Grid.Row="0" Grid.Column="0"
                        DataContext="{Binding SelectedWorkspace}" />

                    <!-- Toolbar -->
                    <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource SurfaceTabBackgroundBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                            Padding="6,2">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource IconButton}" ToolTip="向右分屏 (Ctrl+D)"
                                    Click="ToolbarSplitRight_Click">
                                <TextBlock Text="&#xE26B;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                            </Button>
                            <Button Style="{StaticResource IconButton}" ToolTip="向下分屏 (Ctrl+Shift+D)"
                                    Click="ToolbarSplitDown_Click">
                                <TextBlock Text="&#xE74B;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                            </Button>
                            <Button x:Name="ShellSelectorButton" Style="{StaticResource IconButton}"
                                    ToolTip="用指定 Shell 打开面板..."
                                    Click="ShellSelector_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE756;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                                    <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="7" Margin="2,0,0,0" />
                                </StackPanel>
                            </Button>
                            <Rectangle Width="1" Height="16" Fill="{StaticResource BorderBrush}" Margin="4,0" />
                            <Button Style="{StaticResource IconButton}" ToolTip="布局：两列"
                                    Click="ToolbarLayout2Col_Click">
                                <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                            </Button>
                            <Button Style="{StaticResource IconButton}" ToolTip="布局：2x2 网格"
                                    Click="ToolbarLayoutGrid_Click">
                                <TextBlock Text="&#xE8A9;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                            </Button>
                            <Button Style="{StaticResource IconButton}" ToolTip="布局：主+副"
                                    Click="ToolbarLayoutMainStack_Click">
                                <TextBlock Text="&#xE89F;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                            </Button>
                            <Rectangle Width="1" Height="16" Fill="{StaticResource BorderBrush}" Margin="4,0" />
                            <Button Style="{StaticResource IconButton}" ToolTip="等宽面板"
                                    Click="ToolbarEqualize_Click">
                                <TextBlock Text="&#xE9D5;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                            </Button>
                            <Button x:Name="ToolbarZoomButton" Style="{StaticResource IconButton}" ToolTip="缩放面板 (Ctrl+Shift+Z)"
                                    Click="ToolbarZoom_Click">
                                <TextBlock x:Name="ToolbarZoomIcon" Text="&#xE740;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Terminal content -->
                    <ContentControl Grid.Row="2" Grid.Column="0" x:Name="ContentArea">
                        <controls:SplitPaneContainer x:Name="SplitPaneContainerControl"
                            DataContext="{Binding SelectedWorkspace.SelectedSurface}" />
                    </ContentControl>

                    <!-- Notification panel overlay -->
                    <controls:NotificationPanel Grid.Row="0" Grid.RowSpan="3" Grid.Column="0"
                        HorizontalAlignment="Right"
                        Visibility="{Binding NotificationPanelVisible, Converter={StaticResource BoolToVisibility}}"
                        DataContext="{Binding}" />

                    <!-- Command palette overlay -->
                    <controls:CommandPalette Grid.Row="0" Grid.RowSpan="3" Grid.Column="0"
                        x:Name="CommandPaletteControl"
                        Visibility="Collapsed" />

                    <!-- Snippet picker overlay -->
                    <controls:SnippetPicker Grid.Row="0" Grid.RowSpan="3" Grid.Column="0"
                        x:Name="SnippetPickerControl"
                        Visibility="Collapsed" />

                    <!-- Status bar -->
                    <Border Grid.Row="3" Grid.Column="0" Background="{StaticResource SurfaceTabBackgroundBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                            Padding="10,3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <!-- Git branch -->
                                <TextBlock Text="&#xE8AD;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                           Foreground="{StaticResource ForegroundDimBrush}" VerticalAlignment="Center"
                                           Margin="0,0,4,0" />
                                <TextBlock Text="{Binding SelectedWorkspace.GitBranch, FallbackValue=''}" FontSize="11"
                                           Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"
                                           Margin="0,0,16,0" />
                                <!-- Working directory -->
                                <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                           Foreground="{StaticResource ForegroundDimBrush}" VerticalAlignment="Center"
                                           Margin="0,0,4,0" />
                                <TextBlock Text="{Binding SelectedWorkspace.WorkingDirectory, FallbackValue=''}" FontSize="11"
                                           Foreground="{StaticResource ForegroundDimBrush}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" MaxWidth="300" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <!-- Pane count -->
                                <TextBlock Text="&#xE737;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                           Foreground="{StaticResource ForegroundDimBrush}" VerticalAlignment="Center"
                                           Margin="0,0,4,0" />
                                <TextBlock x:Name="PaneCountText" Text="1 个面板" FontSize="11"
                                           Foreground="{StaticResource ForegroundDimBrush}" VerticalAlignment="Center"
                                           Margin="0,0,12,0" />
                                <!-- Daemon status -->
                                <Border x:Name="DaemonStatusBorder" CornerRadius="3" Padding="5,1" Margin="0,0,12,0"
                                        VerticalAlignment="Center" Background="Transparent">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse x:Name="DaemonStatusDot" Width="6" Height="6"
                                                 Fill="#FF6B7280" Margin="0,0,4,0" VerticalAlignment="Center" />
                                        <TextBlock x:Name="DaemonStatusText" Text="Daemon" FontSize="10"
                                                   Foreground="{StaticResource ForegroundDimBrush}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <!-- Shortcuts hint -->
                                <TextBlock Text="Ctrl+Shift+P：命令面板" FontSize="10"
                                           Foreground="{StaticResource ForegroundDimBrush}" VerticalAlignment="Center"
                                           Opacity="0.6" />
                            </StackPanel>
                        </Grid>
                    </Border>

                </Grid>
            </Grid>

        </Grid>
    </Border>
</Window>
